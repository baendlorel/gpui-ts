{
  "compilerOptions": {
    "target": "esnext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],

    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@zed-gpui/core": ["./packages/core/src"],
      "@zed-gpui/types": ["./packages/types/src"],
      "@zed-gpui/example": ["./packages/example/src"]
    }
  },
  "include": [
    "./dynamicDirectory/**/*.ts",
    "./scripts/**/*.ts",
    "./src/**/*.ts",
    "./draft/**/*.ts",
    "*.config.ts",
    "./tests/**/*.ts",
    "./local-test/**/*.ts",
    "./packages/**/src/**/*.ts"
  ],
  "exclude": ["**/dist/**/*.js", "**/dist/**/*.d.ts", "**/example/**/code/**", "node_modules"],
  "references": [{ "path": "./packages/main" }, { "path": "./packages/example" }]
}
