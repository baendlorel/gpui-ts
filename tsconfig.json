{
  "compilerOptions": {
    "target": "esnext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],

    "declaration": false,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@gpui-ts/core": ["./packages/core/src"],
      "@gpui-ts/types": ["./packages/types/src"],
      "@gpui-ts/example": ["./packages/example/src"]
    }
  },
  "include": [
    "./dynamicDirectory/**/*.ts",
    "./scripts/**/*.ts",
    "./src/**/*.ts",
    "./draft/**/*.ts",
    "*.config.ts",
    "./tests/**/*.ts",
    "./local-test/**/*.ts",
    "./packages/**/src/**/*.ts"
  ],
  "exclude": [
    "**/dist/**/*.js",
    "**/dist/**/*.d.ts",
    "**/example/**/code/**",
    "node_modules"
  ],
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/types" },
    { "path": "./packages/example" }
  ]
}
