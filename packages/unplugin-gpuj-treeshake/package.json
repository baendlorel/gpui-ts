{
  "name": "unplugin-gpuj-treeshake",
  "version": "0.0.1",
  "description": "Unplugin for gpuj tree-shaking optimization - removes unused gpuj methods from bundle",
  "author": {
    "name": "Kasukabe Tsumugi",
    "email": "futami16237@gmail.com"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./noble": {
      "types": "./dist/noble.d.ts",
      "import": "./dist/noble.js",
      "require": "./dist/noble.cjs",
      "default": "./dist/noble.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.cjs",
      "default": "./dist/vite.mjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.mjs",
      "require": "./dist/webpack.cjs",
      "default": "./dist/webpack.mjs"
    },
    "./rollup": {
      "types": "./dist/rollup.d.ts",
      "import": "./dist/rollup.mjs",
      "require": "./dist/rollup.cjs",
      "default": "./dist/rollup.mjs"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.ts",
      "import": "./dist/esbuild.mjs",
      "require": "./dist/esbuild.cjs",
      "default": "./dist/esbuild.mjs"
    },
    "./rspack": {
      "types": "./dist/rspack.d.ts",
      "import": "./dist/rspack.mjs",
      "require": "./dist/rspack.cjs",
      "default": "./dist/rspack.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "keywords": [
    "unplugin",
    "gpuj",
    "tree-shaking",
    "bundle",
    "optimization",
    "vite",
    "webpack",
    "rollup"
  ],
  "peerDependencies": {
    "unplugin": "^1.0.0"
  },
  "devDependencies": {
    "@babel/generator": "^8.0.0",
    "@babel/parser": "^8.0.0",
    "@babel/types": "^8.0.0",
    "@types/node": "^25.9.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "unplugin": "^1.14.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/baendlorel/gpuj",
    "directory": "packages/unplugin-gpuj-treeshake"
  }
}
