  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./inject": {
      "types": "./dist/inject.d.ts",
      "import": "./dist/inject.mjs",
      "default": "./dist/inject.mjs"
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "files": [
    "dist",
    "instruction.md"
  ],
