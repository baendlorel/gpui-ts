{
  "name": "unplugin-zed-gpui",
  "version": "0.0.2",
  "description": "Unplugin for zed-gpui tree-shaking optimization - removes unused zed-gpui methods from bundle",
  "author": {
    "name": "Kasukabe Tsumugi",
    "email": "futami16237@gmail.com"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "keywords": [
    "unplugin",
    "zed-gpui",
    "tree-shaking",
    "bundle",
    "optimization",
    "vite",
    "webpack",
    "rollup"
  ],
  "peerDependencies": {
    "unplugin": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "unplugin": "^1.14.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/baendlorel/gpui-ts",
    "directory": "packages/unplugin-zed-gpui-treeshake"
  },
  "dependencies": {
    "@babel/generator": "^8.0.0",
    "@babel/parser": "^8.0.0",
    "@babel/types": "^8.0.0"
  }
}
